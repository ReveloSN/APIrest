{
  "info": {
    "name": "Biblioteca API",
    "description": "Coleccion para probar la API REST de biblioteca.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "libroId",
      "value": ""
    },
    {
      "key": "usuarioId",
      "value": ""
    },
    {
      "key": "ejemplarId",
      "value": ""
    },
    {
      "key": "prestamoId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Libros",
      "item": [
        {
          "name": "Crear libro",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('creado', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('libroId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isbn\": \"978-0-13-468599-1\",\n  \"titulo\": \"Clean Code\",\n  \"autor\": \"Robert C. Martin\",\n  \"anioPublicacion\": 2008,\n  \"categoria\": \"Programacion\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/libros",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "libros"
              ]
            }
          }
        },
        {
          "name": "Listar libros",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/libros",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "libros"
              ]
            }
          }
        },
        {
          "name": "Consultar libro",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/libros/{{libroId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "libros",
                "{{libroId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Usuarios",
      "item": [
        {
          "name": "Crear usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('creado', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('usuarioId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Ana Torres\",\n  \"correo\": \"ana@uni.edu\",\n  \"tipoUsuario\": \"ESTUDIANTE\",\n  \"codigoEstudiante\": \"EST-001\",\n  \"programa\": \"Ingenieria de Software\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/usuarios",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "usuarios"
              ]
            }
          }
        },
        {
          "name": "Listar usuarios",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/usuarios",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "usuarios"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Ejemplares",
      "item": [
        {
          "name": "Crear ejemplar",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('creado', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('ejemplarId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigoEjemplar\": \"EJ-001\",\n  \"libroId\": \"{{libroId}}\",\n  \"estado\": \"DISPONIBLE\",\n  \"ubicacion\": \"Sala A\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/ejemplares",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "ejemplares"
              ]
            }
          }
        },
        {
          "name": "Listar ejemplares",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/ejemplares",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "ejemplares"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Prestamos",
      "item": [
        {
          "name": "Crear prestamo",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('creado', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('prestamoId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuarioId\": \"{{usuarioId}}\",\n  \"ejemplarId\": \"{{ejemplarId}}\",\n  \"fechaDevolucionEsperada\": \"2026-06-02\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/prestamos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "prestamos"
              ]
            }
          }
        },
        {
          "name": "Listar prestamos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/prestamos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "prestamos"
              ]
            }
          }
        },
        {
          "name": "Prestamos por usuario",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/prestamos/usuario/{{usuarioId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "prestamos",
                "usuario",
                "{{usuarioId}}"
              ]
            }
          }
        },
        {
          "name": "Prestamos por ejemplar",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/prestamos/ejemplar/{{ejemplarId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "prestamos",
                "ejemplar",
                "{{ejemplarId}}"
              ]
            }
          }
        },
        {
          "name": "Registrar devolucion",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/prestamos/{{prestamoId}}/devolucion",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "prestamos",
                "{{prestamoId}}",
                "devolucion"
              ]
            }
          }
        }
      ]
    }
  ]
}
